      "dependencies": [
        {
          "name": "connect_nutanix_uuid",
          "redo_new": true,
          "redo_change": true
        }
      ]
    },
    {
      "tag": "connect_nutanix_name",
      "label": "Nutanix VM Name",
      "description": "The VM name in Nutanix.",
      "type": "string",
      "group": "connect_nutanix_nutanix",
      "dependencies": [
        {
          "name": "connect_nutanix_uuid",
          "redo_new": true,
          "redo_change": true
        }
      ]
    },
    {
      "tag": "connect_nutanix_uuid",
      "label": "Nutanix VM UUID",
      "description": "The VM unique identifier in Nutanix.",
      "type": "string",
      "group": "connect_nutanix_nutanix"
    },
    {
      "tag": "connect_nutanix_power_state",
      "label": "Nutanix Power State",
