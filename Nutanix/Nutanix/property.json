  "scripts": [

    {
      "name": "nutanix_test.py",
      "test": true
    },

    {
      "name": "nutanix_poll.py",
      "discovery": true
    },
    {
      "name": "nutanix_resolve.py",
      "properties": [
        "connect_nutanix_name",
        "connect_nutanix_description",
        "connect_nutanix_power_state"
